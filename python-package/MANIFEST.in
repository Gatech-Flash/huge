include README.md
include CHANGELOG.md
include CONTRIBUTING.md
include pyproject.toml
include mkdocs.yml
recursive-include docs *.md
recursive-include examples *.py
recursive-include scripts *.py *.sh
recursive-include cpp *.cpp *.h
